import os
import json
from typing import List, Optional
from pydantic import BaseModel, Field
from google import genai
from google.genai import types

# =====================================================================
# 1. Pydantic JSON Schema 規範 (方案 A：雙語 _zh / _en 後綴)
# =====================================================================

class AssetGroup(BaseModel):
    name_zh: str = Field(..., description="資產或標的族群名稱 (中文)")
    name_en: str = Field(..., description="Asset or group name (English)")
    reason_zh: str = Field(..., description="推薦或避險原因說明 (中文)")
    reason_en: str = Field(..., description="Recommendation or risk reason (English)")


class GlobalVix(BaseModel):
    value: float = Field(..., description="VIX 當前指標數值")
    status_zh: str = Field(..., description="VIX 狀態描述 (中文)")
    status_en: str = Field(..., description="VIX status description (English)")
    insight_zh: str = Field(..., description="VIX 核心市場洞察與策略建議 (中文)")
    insight_en: str = Field(..., description="VIX core insight and strategic advice (English)")


class NewsItem(BaseModel):
    title_zh: str = Field(..., description="新聞/訊號標題 (中文)")
    title_en: str = Field(..., description="News/Signal title (English)")
    ai_sentiment: str = Field(..., description="AI 分析情緒：Bullish / Bearish / Neutral")
    vol_multiplier: str = Field(..., description="波動度倍數預估 (例如 '1.4x')")
    source: str = Field(..., description="新聞或數據來源")
    macro_attribution_zh: str = Field(..., description="總經與市場歸因分析，包含情緒指數 (中文)")
    macro_attribution_en: str = Field(..., description="Macro attribution analysis including sentiment index (English)")
    tw_spillover_effect_zh: str = Field(..., description="台股或跨市場連動外溢效應 (中文)")
    tw_spillover_effect_en: str = Field(..., description="Taiwan or cross-market spillover effect (English)")
    rwa_flow_metric: str = Field(..., description="RWA 資金池流向數據 (例如 '+$52.4M Pool Inflow')")
    agent_action_log: str = Field(..., description="Agent 執行日誌紀錄 (例如 '[AGENT EXEC] Rebalanced...')")
    
    recommended_groups_tw: List[AssetGroup] = Field(default_factory=list, description="台股推薦投資族群")
    high_risk_groups_tw: List[AssetGroup] = Field(default_factory=list, description="台股高風險/避險族群")
    recommended_groups_us: List[AssetGroup] = Field(default_factory=list, description="美股/美債推薦投資族群")
    high_risk_groups_us: List[AssetGroup] = Field(default_factory=list, description="美股高風險/避險族群")


class MarketIntelligenceReport(BaseModel):
    global_vix: GlobalVix = Field(..., description="全球 VIX 恐慌指數模組")
    us_macro: List[NewsItem] = Field(..., description="美股與全球總經新聞分析")
    web3_crypto: List[NewsItem] = Field(..., description="Web3 / 加密貨幣 / RWA 市場分析")
    tw_stocks: List[NewsItem] = Field(..., description="台股與半導體供應鏈分析")


# =====================================================================
# 2. Prompt 結構設定
# =====================================================================

SYSTEM_INSTRUCTION = """
你是一個頂級的量化總經與 Web3/台股 跨市場 AI 分析師。
你的任務是將輸入的原始市場新聞數據，轉化為標準化的「市場情報與 Agent 再平衡 JSON 報告」。

【輸出規則與規範】
1. 嚴格遵循提供的 JSON Schema，不得遺漏任何必填欄位。
2. 所有敘述性欄位必須同時提供繁體中文 (_zh) 與 英文 (_en) 兩種版本。
3. 如果輸入新聞為英文，請翻譯並精煉為繁體中文至 _zh 欄位；若輸入為中文，請精確翻譯為英文至 _en 欄位。
4. 針對 VIX > 20 的風險情境，相應的資產推薦應偏向 Real Yield (RWA)、美債與防禦型標的。
5. ai_sentiment 僅能輸出: "Bullish", "Bearish", 或 "Neutral"。
"""


def build_user_prompt(raw_data: dict) -> str:
    """根據輸入數據構建 User Prompt"""
    return f"""
請分析以下原始市場情報數據，並依據 Schema 生成完整的雙語市場情報分析報告：

【原始情報數據】
{json.dumps(raw_data, ensure_ascii=False, indent=2)}
"""


# =====================================================================
# 3. RAG Pipeline 執行函式
# =====================================================================

def run_rag_pipeline(raw_input_data: dict) -> dict:
    """
    執行 RAG Pipeline 生成符合雙語 Schema 的市場情報報告
    """
    client = genai.Client(api_key=os.getenv("GEMINI_API_KEY"))

    # 呼叫 Gemini 並傳入 Structured Output (Pydantic Schema)
    response = client.models.generate_content(
        model="gemini-2.5-flash",
        contents=build_user_prompt(raw_input_data),
        config=types.GenerateContentConfig(
            system_instruction=SYSTEM_INSTRUCTION,
            response_mime_type="application/json",
            response_schema=MarketIntelligenceReport,
            temperature=0.2, # 低隨機性，確保輸出穩定符合 Schema
        ),
    )

    # 回傳 JSON 字典格式
    return json.loads(response.text)


# =====================================================================
# 4. 測試範例
# =====================================================================

if __name__ == "__main__":
    # 模擬 RAG 上游收集到的 Raw Data
    sample_raw_input = {
        "vix_value": 22.4,
        "raw_news": [
            {
                "category": "us_macro",
                "title": "Dow Jones Futures: Market Sells Off On Oil Prices, Google, Tesla",
                "source": "Yahoo Finance US",
                "content": "The Nasdaq undercut key levels as Google and Tesla led titans lower while oil prices soared."
            },
            {
                "category": "web3_crypto",
                "title": "Coinbase lets businesses accept USDC payments from AI agents",
                "source": "Cointelegraph",
                "content": "The exchange introduced AI trading tools and developer kit for autonomous AI agents."
            },
            {
                "category": "tw_stocks",
                "title": "台積電加碼投資美國1000億美元 經濟部：最大產能仍留台灣",
                "source": "Google News TW",
                "content": "台積電亞利桑那擴廠引發討論，經濟部強調核心 2 奈米與先進封裝 CoWoS 主力產能仍留台灣。"
            }
        ]
    }

    print("🚀 正在執行 RAG Pipeline 分析...")
    structured_report = run_rag_pipeline(sample_raw_input)
    
    # 印出標準雙語 JSON 結果
    print(json.dumps(structured_report, ensure_ascii=False, indent=2))
